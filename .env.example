# LexAI Backend Environment Variables
# Render pe ye variables Environment section me daalo — ye file upload mat karna!

GEMINI_API_KEY=
PORT=3000

# Optional: extra CORS origins (comma-separated), e.g. https://preview-123.example.com
# ALLOWED_ORIGINS=

# ── API abuse / quota protection ─────────────────────────
# Same random string on server AND in site <meta name="lexai-client-key" content="...">
# Empty = no client key required (browser-only; not a full secret on static sites)
# CLIENT_API_KEY=

# Per IP: max analyze calls per window (default 15 min window, 6 calls)
# RATE_WINDOW_MS=900000
# RATE_MAX_ANALYZE=6

# Per IP per UTC day (0 = disabled). Example: 50 analyses/day/IP
# DAILY_MAX_PER_IP=0

# Max characters accepted (must match frontend MAX_TEXT_CHARS in host/index.html)
# MAX_DOCUMENT_CHARS=8000
# PROMPT_CHARS=4000

# JSON body max (default 512kb)
# JSON_BODY_LIMIT=512kb
